# =============================================================================
# Cursor PQE harness — environment variables
# Copy to .env (not tracked) and fill in real values.
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram bot (used by Claude Code and Antigravity to ping stage completion)
# -----------------------------------------------------------------------------
# How to set this up:
#   1. Open Telegram, search for @BotFather, start a chat.
#   2. Send `/newbot`, follow the prompts (name + username ending in `bot`).
#      BotFather replies with an HTTP API token — that's TELEGRAM_BOT_TOKEN.
#   3. Send any message to your new bot from your personal Telegram account.
#   4. Open https://api.telegram.org/bot<TOKEN>/getUpdates in a browser.
#      The JSON has `chat.id` — that's TELEGRAM_CHAT_ID.
#   5. Paste both below.
#   6. From the repo root: `python tooling/telegram_bot.py "hello" stage`
#      — expect "telegram: sent" and a message on your phone.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# -----------------------------------------------------------------------------
# Cursor app
# -----------------------------------------------------------------------------
# Path to the Cursor app bundle. Used by harness/electron/launch.ts.
# Default works for the App Store and direct-download installs.
CURSOR_APP_PATH=/Applications/Cursor.app

# Optional: pin to a specific Cursor build so Playwright doesn't flake when
# Cursor auto-updates mid-suite. Read by launch.ts; if unset, no pinning check.
# CURSOR_VERSION=

# -----------------------------------------------------------------------------
# Ollama (used by voc/classify/ for local LLM-based VoC classification)
# -----------------------------------------------------------------------------
# Install on macOS: `brew install ollama && ollama pull llama3.1:8b`
# Disk footprint: ~5 GB for the 8B model. Set to `phi3.5:3.8b-mini-instruct-q4_K_M`
# (~2 GB) on space-constrained machines.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# -----------------------------------------------------------------------------
# Postgres (VoC dashboard backend; brought up via docker-compose)
# -----------------------------------------------------------------------------
POSTGRES_USER=voc
POSTGRES_PASSWORD=voc_local_only
POSTGRES_DB=voc
POSTGRES_PORT=5436

# -----------------------------------------------------------------------------
# Metabase (VoC dashboard UI)
# -----------------------------------------------------------------------------
METABASE_PORT=3033

# -----------------------------------------------------------------------------
# Bugbot PR injection spec — defensive guard
# -----------------------------------------------------------------------------
# The CVE-recreation spec for Bugbot PR injection refuses to run unless this
# env var points at a LOCAL Bugbot-clone stub. This is a hard safety net to
# prevent the spec from ever firing against the real Bugbot service.
# Set this only if you've stood up the local stub in malicious_mcp/github_clone/.
# BUGBOT_CLONE_URL=
